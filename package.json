    "@types/supertest": "^7.2.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.1",
    "ejs": "^5.0.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.5.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.9.1",
    "prisma": "^7.5.0",
    "socket.io": "^4.8.3",
    "winston": "^3.11.0",
    "xendit-node": "^7.0.0",
    "zod": "^3.22.4"
