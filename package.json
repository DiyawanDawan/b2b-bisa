{
  "name": "hello-prisma",
  "version": "1.0.0",
  "description": "Prisma v7 ESM setup",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "generate": "prisma generate && node scripts/compile-prisma-client.mjs",
    "db:migrate": "prisma migrate deploy",
    "db:setup": "prisma migrate deploy && npm run generate",
    "seed": "prisma db seed",
    "seed:forum-groups": "tsx prisma/seed/run-forum-groups.js",
    "seed:forum-group-posts": "tsx prisma/seed/run-forum-group-posts.js",
    "seed:reviews": "tsx prisma/seed/run-reviews-delivery.js",
    "seed:partnerships": "tsx prisma/seed/run-partnerships.js",
    "seed:bisa-express": "tsx scripts/seed-bisa-express.ts",
    "build": "tsc -p tsconfig.build.json && node scripts/compile-prisma-client.mjs && node scripts/fix-dist-esm-imports.mjs && node scripts/copy-ejs-templates.mjs && node scripts/copy-data-assets.mjs",
    "build:docker": "npm run build && node scripts/prepare-prod-package.mjs",
    "start:prod": "dotenv -e .env.production -- node dist/src/index.js",
    "pm2:start:dev": "pm2 start ecosystem.config.cjs --only buka-lombok-be --env development",
    "pm2:start:prod": "pm2 start ecosystem.config.cjs --only buka-lombok-be-prod --env production",
    "predev": "npm run generate",
    "dev": "tsx watch src/index.ts",
    "test": "cross-env NODE_ENV=test jest",
    "test:unit": "cross-env NODE_ENV=test jest tests/unit --forceExit",
    "test:integration": "cross-env NODE_ENV=test jest tests/integration --forceExit",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --forceExit",
    "test:encryption": "tsx scripts/verify-encryption.ts",
    "seed:vouchers": "node scripts/seed-vouchers.js",
    "ml:download-datasets": "cd ../ml && python scripts/scrape_datasets.py download --source all",
    "ml:scrape-discover": "cd ../ml && python scripts/scrape_datasets.py discover",
    "ml:scrape-pipeline": "cd ../ml && python scripts/scrape_datasets.py pipeline"
  },
  "prisma": {
    "seed": "tsx prisma/seed/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "imports": {
    "#prisma": "./generated/prisma/client.js",
    "#db": "./src/config/prisma.ts",
    "#types/*": "./src/types/*.ts",
    "#controllers/*": "./src/controllers/*.ts",
    "#services/*": "./src/services/*.ts",
    "#middlewares/*": "./src/middlewares/*.ts",
    "#utils/*": "./src/utils/*.ts",
    "#routes/*": "./src/routes/*.ts",
    "#config/*": "./src/config/*.ts",
    "#validations/*": "./src/validations/*.ts",
    "#constants/*": "./src/constants/*.ts",
    "#crons/*": "./src/crons/*.ts",
    "#worker/*": "./src/workers/*.ts",
    "#xendit/payment_request/models": "./src/xendit/payment_request/models.ts",
    "#xendit/refund/models": "./src/xendit/refund/models.ts",
    "#xendit/payout/models": "./src/xendit/payout/models.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@aws-sdk/lib-storage": "^3.1015.0",
    "@aws-sdk/s3-request-presigner": "^3.1061.0",
    "@chroma-core/default-embed": "^0.1.9",
    "@prisma/adapter-mariadb": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/supertest": "^7.2.0",
    "bcrypt": "^6.0.0",
    "chromadb": "^3.4.3",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.1",
    "ejs": "^5.0.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.1.0",
    "jest-mock-extended": "^4.0.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.5.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.9.1",
    "pdf-parse": "^1.1.4",
    "prisma": "^7.5.0",
    "pusher": "^5.2.0",
    "redis": "^4.7.0",
    "slugify": "^1.6.9",
    "socket.io": "^4.8.3",
    "winston": "^3.11.0",
    "xendit-node": "^7.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^8.4.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.5",
    "@types/node-fetch": "^2.6.11",
    "@types/nodemailer": "^6.4.14",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "cross-env": "^7.0.3",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.15.7",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.1"
  }
}
