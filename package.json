{
  "name": "hello-prisma",
  "version": "1.0.0",
  "description": "Prisma v7 ESM setup",
  "type": "module",
  "main": "script.ts",
  "scripts": {
    "start": "tsx script.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "generate": "prisma generate",
    "seed": "prisma db seed",
    "dev": "tsx watch src/index.ts"
  },
