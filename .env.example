DATABASE_URL=
JWT_SECRET=
SMTP_USER=
SMTP_PASS=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public bucket URL (e.g. https://pub-xxxxx.r2.dev). NOT *.r2.cloudflarestorage.com
# Leave empty to serve via API proxy at /api/v1/storage/assets/
R2_PUBLIC_URL=
# Public API host for asset URLs (no /api/v1 suffix). Use ngrok/LAN IP for mobile dev.
API_PUBLIC_URL=
# Optional override for media URLs (defaults to API_PUBLIC_URL)
MEDIA_BASE_URL=
XENDIT_PUBLIC_URL=
# ─────────────────────────────────────────────────────────────────────────────
# Xendit API Keys — Buat di Xendit Dashboard → Settings → Developers → API Keys
#
# WAJIB: untuk setiap key, aktifkan permission berikut (Write):
#   • Invoices              → untuk /pay mode WEB (Hosted Checkout)
#   • Payment Methods       → untuk Payment Request V3 mobile (VA/QRIS/E-Wallet)
#   • Payment Requests      → untuk Payment Request V3 mobile
#   • Refunds               → untuk pembatalan / dispute
#   • Payouts (opsional)    → khusus XENDIT_PAYOUT_SECRET_KEY untuk withdraw
#
# Jika 403 REQUEST_FORBIDDEN_ERROR saat pilih BNI/VA/QRIS, artinya permission
# "Payment Requests" / "Payment Methods" belum Write di API key TEST.
# Save → tunggu 1–2 menit → coba lagi.
#
# Development: jika 403, backend otomatis fallback ke Invoice (hosted checkout)
# XENDIT_FALLBACK_TO_INVOICE_ON_FORBIDDEN=false
#
# Jika Invoice juga 403 (key tanpa izin sama sekali), default di development:
# pakai VA/QR simulasi. Matikan dengan XENDIT_MOCK_ON_FORBIDDEN=false
# Paksa mock dari awal (tanpa panggil Xendit): XENDIT_MOCK_PAYMENT=true
#
# ── Webhook development (Xendit real + ngrok, BUKAN mock DB langsung) ──
# XENDIT_WEBHOOK_DEV=true
# XENDIT_MOCK_PAYMENT=false
# XENDIT_MOCK_ON_FORBIDDEN=false
# XENDIT_FALLBACK_TO_INVOICE_ON_FORBIDDEN=false
# API_PUBLIC_URL=https://xxxx.ngrok-free.app
# Daftarkan di Xendit Dashboard → Developers → Callbacks:
#   Payment Request v3 → https://xxxx.ngrok-free.app/api/v1/payments/session-webhook
#   Invoice (legacy)   → https://xxxx.ngrok-free.app/api/v1/payments/xendit-webhook
# XENDIT_WEBHOOK_TOKEN harus SAMA dengan Verification Token di Callbacks Xendit.
#
# Simulasi lunas (non-production):
#   POST /api/v1/orders/:id/simulate-payment  → mock langsung ATAU Xendit /v3/payment_requests/.../simulate
#   POST /api/v1/orders/:id/mock-confirm-payment  → alias simulate (legacy)
# Batalkan VA/QR pending:
#   POST /api/v1/orders/:id/cancel-payment  → Xendit cancel + reset transaksi
# ─────────────────────────────────────────────────────────────────────────────
XENDIT_PAYMENT_SECRET_KEY=
# Payout / withdraw supplier wallet — boleh key terpisah biar scope kecil.
XENDIT_PAYOUT_SECRET_KEY=
# Legacy fallback: dipakai otomatis jika XENDIT_PAYMENT_SECRET_KEY kosong.
XENDIT_SECRET_KEY=
# Harus SAMA PERSIS dengan "Verification Token" / "Callback token" di
# Xendit Dashboard → Developers → Callbacks
XENDIT_WEBHOOK_TOKEN=
# Aktifkan alur webhook development (simulasi lunas lewat POST session-webhook)
# XENDIT_WEBHOOK_DEV=true

# Firebase Admin / FCM
# Prefer FIREBASE_SERVICE_ACCOUNT (single-line JSON string of the service account).
# Generate at: Firebase Console → Project Settings → Service accounts → Generate new private key
# Example:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"bisa-xxxx","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@bisa-xxxx.iam.gserviceaccount.com",...}
FIREBASE_SERVICE_ACCOUNT=
# Dev convenience: path ke file JSON di luar repo. JANGAN commit file ini.
# FIREBASE_SERVICE_ACCOUNT_PATH=../secrets/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=

# RajaOngkir Shipping Cost API — https://rajaongkir.com/docs
# Dashboard → API Key (Shipping Cost, bukan Payment/Delivery)
SHIPPING_COST_API_KEY=
RAJAONGKIR_BASE_URL=https://rajaongkir.komerce.id/api/v1
RAJAONGKIR_DEFAULT_COURIERS=jne:jnt:sicepat:anteraja:tiki:pos
