DATABASE_URL=
JWT_SECRET=
# AES-256-GCM field encryption (rekening bank, providerActions, NPWP).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
# Optional during key rotation (decrypt v2: ciphertext prefix)
# ENCRYPTION_KEY_V2=

# Chunked media upload (R2 multipart)
MEDIA_CHUNK_SIZE_BYTES=5242880
MEDIA_UPLOAD_SESSION_TTL_HOURS=24
MEDIA_MAX_IMAGE_BYTES=52428800
MEDIA_MAX_PDF_BYTES=20971520
# true = chunks via backend proxy (dev); false = presigned PUT langsung ke R2
MEDIA_UPLOAD_PROXY_MODE=true

# Redis cache (Tier A — kategori, GIS, policies, dll. BUKAN stok/harga/cart)
# REDIS_ENABLED=false → bypass DB langsung (default aman untuk dev)
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=bisa:v1
REDIS_DEFAULT_TTL_SECONDS=3600
REDIS_ENABLED=false

# Readiness gates v26 — blok upload produk ACTIVE / negosiasi / checkout jika profil belum lengkap
READINESS_GATES_ENABLED=true
READINESS_ENFORCE_ADMIN=false
# true = supplier wajib KYC verified sebelum produk ACTIVE
REQUIRE_KYC_FOR_ACTIVE_PRODUCT=false

SMTP_PASS=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public bucket URL (e.g. https://pub-xxxxx.r2.dev). NOT *.r2.cloudflarestorage.com
# Leave empty to serve via API proxy at /api/v1/storage/assets/
R2_PUBLIC_URL=
# Public API host for asset URLs (no /api/v1 suffix). Use ngrok/LAN IP for mobile dev.
API_PUBLIC_URL=
# Optional override for media URLs (defaults to API_PUBLIC_URL)
MEDIA_BASE_URL=
XENDIT_PUBLIC_URL=
# ─────────────────────────────────────────────────────────────────────────────
# Xendit API Keys — Buat di Xendit Dashboard → Settings → Developers → API Keys
#
# WAJIB: untuk setiap key, aktifkan permission berikut (Write):
#   • Invoices              → untuk /pay mode WEB (Hosted Checkout)
#   • Payment Methods       → untuk Payment Request V3 mobile (VA/QRIS/E-Wallet)
#   • Payment Requests      → untuk Payment Request V3 mobile
#   • Refunds               → untuk pembatalan / dispute
#   • Payouts (opsional)    → khusus XENDIT_PAYOUT_SECRET_KEY untuk withdraw
#
# Jika 403 REQUEST_FORBIDDEN_ERROR saat pilih BNI/VA/QRIS, artinya permission
# "Payment Requests" / "Payment Methods" belum Write di API key TEST.
# Save → tunggu 1–2 menit → coba lagi.
#
# Development: jika 403, backend otomatis fallback ke Invoice (hosted checkout)
# XENDIT_FALLBACK_TO_INVOICE_ON_FORBIDDEN=false
#
# Jika Invoice juga 403 (key tanpa izin sama sekali), default di development:
# pakai VA/QR simulasi. Matikan dengan XENDIT_MOCK_ON_FORBIDDEN=false
# Paksa mock dari awal (tanpa panggil Xendit): XENDIT_MOCK_PAYMENT=true
#
# ── Webhook development (Xendit real + ngrok, BUKAN mock DB langsung) ──
# XENDIT_WEBHOOK_DEV=true
# XENDIT_MOCK_PAYMENT=false
# XENDIT_MOCK_ON_FORBIDDEN=false
# XENDIT_FALLBACK_TO_INVOICE_ON_FORBIDDEN=false
# API_PUBLIC_URL=https://xxxx.ngrok-free.app
# URL landing verifikasi/lacak (admin Next.js, default port 3001)
CLIENT_HOST=http://localhost:3001
PUBLIC_VERIFY_BASE_URL=http://localhost:3001
SUPPORT_WHATSAPP=6281234567890
SUPPORT_EMAIL=cs@bisa.id
# Daftarkan di Xendit Dashboard → Developers → Callbacks:
#   Payment Request v3 → https://xxxx.ngrok-free.app/api/v1/payments/session-webhook
#   Invoice (legacy)   → https://xxxx.ngrok-free.app/api/v1/payments/xendit-webhook
# XENDIT_WEBHOOK_TOKEN harus SAMA dengan Verification Token di Callbacks Xendit.
#
# Simulasi lunas (non-production):
#   POST /api/v1/orders/:id/simulate-payment  → mock langsung ATAU Xendit /v3/payment_requests/.../simulate
#   POST /api/v1/orders/:id/mock-confirm-payment  → alias simulate (legacy)
# Batalkan VA/QR pending:
#   POST /api/v1/orders/:id/cancel-payment  → Xendit cancel + reset transaksi
# ─────────────────────────────────────────────────────────────────────────────
XENDIT_PAYMENT_SECRET_KEY=
# Payout / withdraw supplier wallet — boleh key terpisah biar scope kecil.
XENDIT_PAYOUT_SECRET_KEY=
# Legacy fallback: dipakai otomatis jika XENDIT_PAYMENT_SECRET_KEY kosong.
XENDIT_SECRET_KEY=
# Harus SAMA PERSIS dengan "Verification Token" / "Callback token" di
# Xendit Dashboard → Developers → Callbacks
XENDIT_WEBHOOK_TOKEN=
# Aktifkan alur webhook development (simulasi lunas lewat POST session-webhook)
# XENDIT_WEBHOOK_DEV=true

# BISA ML — XGBoost predict (ml-bisa FastAPI, port 8000)
# cd ml-bisa && ../ml/.venv/Scripts/uvicorn.exe app.main:app --reload --port 8000
ML_SERVICE_URL=http://127.0.0.1:8000
ML_PREDICT_ENABLED=true
# ML_SERVICE_API_KEY=

# Google Gemini — chatbot + Market AI insight (opsional tapi disarankan)
# GOOGLE_GEMINI_API_KEY=

# Chroma Cloud — RAG knowledge base (admin upload → chatbot)
# Buat API key di dashboard Chroma → scope database "bisa"
CHROMA_API_KEY=
CHROMA_TENANT_ID=5f0969bb-9cbf-43c2-9fb5-130785014b2e
CHROMA_DATABASE=bisa
CHROMA_COLLECTION=bisa_knowledge
RAG_ENABLED=true

# Stock photos untuk seed produk (Pexels utama, Pixabay fallback) → unduh ke R2
# Pexels: https://www.pexels.com/api/documentation/
# Catatan: query "biochar" di Pexels sudah punya banyak foto/video — dipakai default untuk produk BIOCHAR.
PEXELS_API_KEY=
# Pixabay: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# Firebase Admin / FCM
# Option A (recommended for Docker): mount JSON file, set path only
#   volumes: ./secrets/firebase-service-account.json:/app/secrets/firebase.json:ro
#   FIREBASE_SERVICE_ACCOUNT_PATH=/app/secrets/firebase.json
#
# Option B: single-line JSON in env (private_key MUST use \n not real newlines)
#   On server: cat firebase.json | jq -c .   → paste output below
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"bisa-xxxx","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxx@bisa-xxxx.iam.gserviceaccount.com",...}
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_SERVICE_ACCOUNT_PATH=

# RajaOngkir Shipping Cost API — https://rajaongkir.com/docs
# Dashboard → API Key (Shipping Cost, bukan Payment/Delivery)
SHIPPING_COST_API_KEY=
RAJAONGKIR_BASE_URL=https://rajaongkir.komerce.id/api/v1
RAJAONGKIR_DEFAULT_COURIERS=jne:jnt:sicepat:anteraja:tiki:pos
