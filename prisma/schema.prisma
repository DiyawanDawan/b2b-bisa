// =========================================================
// FORUM & COMMUNITY
// =========================================================

model ForumGroup {
  id          String   @id @default(uuid())
  name        String   @map("name")
  slug        String   @unique @map("slug")
  description String?  @db.Text @map("description")
  avatarUrl   String?  @map("avatar_url")
  bannerUrl   String?  @map("banner_url")
  ownerId     String   @map("owner_id")
  isPublic    Boolean  @default(true) @map("is_public")
  memberCount Int      @default(1) @map("member_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner   User               @relation("ForumGroupOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members ForumGroupMember[]
  posts   ForumPost[]

  @@index([ownerId])
  @@index([isPublic])
  @@index([createdAt])
  @@map("forum_groups")
}

model ForumGroupMember {
  id       String          @id @default(uuid())
  groupId  String          @map("group_id")
  userId   String          @map("user_id")
  role     ForumGroupRole  @default(MEMBER) @map("role")
  joinedAt DateTime        @default(now()) @map("joined_at")

  group ForumGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@map("forum_group_members")
}

model ForumPost {
  id        String         @id @default(uuid())
  userId    String         @map("user_id")
  title     String         @map("title")
  content   String         @db.Text @map("content")
  mediaUrls Json?          @map("media_urls")
  // Hashtag (#xxx) yang di-extract dari content saat create/update,
  // di-merge dengan tags eksplisit yang dikirim user. Dipakai untuk
  // filter "trending tag" & search by tag.
  tags Json? @map("tags")
  // Snapshot produk yang di-mention (@produk) saat post dibuat, isi
  // `{id, name, slug}` — dipakai mobile untuk render chip clickable
  // tanpa harus query produk lagi.
  productMentions Json? @map("product_mentions")
  categoryId String?        @map("category_id")
  groupId    String?        @map("group_id")
  status    PostStatus     @default(PUBLISHED) @map("status")
  viewCount Int            @default(0) @map("view_count")
  upvotes   Int            @default(0) @map("upvotes")
  downvotes Int            @default(0) @map("downvotes")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  user      User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  category  Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  group     ForumGroup?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  comments  ForumComment[]
  votes     ForumVote[]    @relation("PostVotes")

  @@index([userId])
  @@index([categoryId])
  @@index([groupId])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([status, categoryId])
  @@index([status, createdAt])
  @@map("forum_posts")
}

model ForumComment {
  id        String    @id @default(uuid())
  postId    String    @map("post_id")
  userId    String    @map("user_id")
  parentId  String?   @map("parent_id")
  content   String    @db.Text @map("content")
  mediaUrls Json?     @map("media_urls")
  upvotes   Int       @default(0) @map("upvotes")
  downvotes Int       @default(0) @map("downvotes")
  createdAt DateTime  @default(now()) @map("created_at")

  post      ForumPost       @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent    ForumComment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   ForumComment[]  @relation("CommentReplies")
  user      User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  votes     ForumVote[]     @relation("CommentVotes")

  @@index([postId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
  @@map("forum_comments")
}

model ForumVote {
  id        String   @id @default(uuid())
  postId    String?  @map("post_id")
  commentId String?  @map("comment_id")
  userId    String   @map("user_id")
  type      VoteType @map("type")
  createdAt DateTime @default(now()) @map("created_at")

  post      ForumPost?    @relation("PostVotes", fields: [postId], references: [id], onDelete: Cascade)
  comment   ForumComment? @relation("CommentVotes", fields: [commentId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@map("forum_votes")
}

model Article {
  id            String          @id @default(uuid())
  title         String          @map("title")
