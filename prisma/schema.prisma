  biomassaType           String?  @map("biomassa_type")
  grade                  String?  @map("grade")
  productCount           Int      @default(0) @map("product_count")
  listingCount           Int      @default(0) @map("listing_count")
  totalStockKg           Int      @default(0) @map("total_stock_kg")
  totalStockTon          Decimal  @default(0) @db.Decimal(12, 2) @map("total_stock_ton")
  provinceCount          Int      @default(0) @map("province_count")
  orderCount30d          Int      @default(0) @map("order_count_30d")
  orderCount90d          Int      @default(0) @map("order_count_90d")
  openOrderCount         Int      @default(0) @map("open_order_count")
  quantityKg30d          Int      @default(0) @map("quantity_kg_30d")
  quantityKg90d          Int      @default(0) @map("quantity_kg_90d")
