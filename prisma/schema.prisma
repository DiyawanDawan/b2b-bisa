// =========================================================
// GEOGRAPHIC & ADDRESS MANAGEMENT
// =========================================================

model Country {
  id         String     @id @default(uuid())
  sequenceId Int        @unique @default(autoincrement()) @map("sequence_id")
  name       String     @unique @map("name")
  continent  String     @map("continent")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  code       String     @unique @map("code")
  addresses  Address[]  @relation("CountryAddress")
  provinces  Province[] @relation("CountryProvinces")

  @@index([sequenceId])
  @@index([name])
  @@index([createdAt])
  @@map("countries")
}

model Province {
  id         String    @id @default(uuid())
  sequenceId Int       @unique @default(autoincrement()) @map("sequence_id")
  countryId  String    @map("country_id")
  name       String    @map("name")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  code       String    @map("code")
  shortCode  String?   @map("short_code")
  addresses  Address[] @relation("ProvinceAddress")
  country    Country   @relation("CountryProvinces", fields: [countryId], references: [id], onDelete: Restrict)
  regencies  Regency[] @relation("ProvinceRegencies")

  @@unique([name, countryId])
  @@unique([code, countryId])
  @@index([sequenceId])
  @@index([name])
  @@index([createdAt])
  @@map("provinces")
}

model Regency {
  id         String     @id @default(uuid())
  sequenceId Int        @unique @default(autoincrement()) @map("sequence_id")
  provinceId String     @map("province_id")
  name       String
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  code       String     @map("code")
  shortCode  String?    @map("short_code")
  addresses  Address[]  @relation("RegencyAddress")
  districts  District[] @relation("RegencyDistricts")
  province   Province   @relation("ProvinceRegencies", fields: [provinceId], references: [id], onDelete: Restrict)

  @@unique([name, provinceId])
  @@unique([code, provinceId])
  @@index([sequenceId])
  @@index([name])
  @@index([createdAt])
  @@map("regencies")
}

model District {
  id         String    @id @default(uuid())
  sequenceId Int       @unique @default(autoincrement()) @map("sequence_id")
  regencyId  String    @map("regency_id")
  name       String
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  code       String    @map("code")
  addresses  Address[] @relation("DistrictAddress")
  regency    Regency   @relation("RegencyDistricts", fields: [regencyId], references: [id], onDelete: Restrict)
  villages   Village[] @relation("DistrictVillages")

  @@unique([name, regencyId])
  @@unique([code, regencyId])
  @@index([sequenceId])
  @@index([createdAt])
  @@map("districts")
}

model Village {
  id         String      @id @default(uuid())
  sequenceId Int         @unique @default(autoincrement()) @map("sequence_id")
  districtId String      @map("district_id")
  name       String
  type       VillageType @default(DESA)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  code       String      @map("code")
  addresses  Address[]   @relation("VillageAddress")
  district   District    @relation("DistrictVillages", fields: [districtId], references: [id], onDelete: Restrict)

  @@unique([name, districtId])
  @@unique([code, districtId])
  @@index([sequenceId])
  @@index([createdAt])
  @@map("villages")
}

model Address {
  id          String  @id @default(uuid())
  sequenceId  Int     @unique @default(autoincrement()) @map("sequence_id")
  countryId   String  @map("country_id")
  provinceId  String? @map("province_id")
  regencyId   String? @map("regency_id")
  districtId  String? @map("district_id")
  villageId   String? @map("village_id")
  fullAddress String  @map("full_address") @db.Text
  zipCode     String  @map("zip_code")
  phoneNumber String? @map("phone_number")
  latitude    Decimal @db.Decimal(9, 6)
  longitude   Decimal @db.Decimal(10, 6)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  country           Country           @relation("CountryAddress", fields: [countryId], references: [id])
  province          Province?          @relation("ProvinceAddress", fields: [provinceId], references: [id])
  regency           Regency?           @relation("RegencyAddress", fields: [regencyId], references: [id])
  district          District?          @relation("DistrictAddress", fields: [districtId], references: [id])
  village           Village?           @relation("VillageAddress", fields: [villageId], references: [id])

  // Relations to other business models
  users             User[]
  userProfile       UserProfile?
  shippingOrders    Order[]           @relation("ShippingAddress")
  partner           Partner?
  companyProfile    CompanyProfile?
  shippingCenter    ShippingCenter?
  customerAddresses CustomerAddress[]
  bisaExpressHubs   BisaExpressHub[]

  @@index([sequenceId])
  @@index([createdAt])
  @@map("addresses")
}

model CustomerAddress {
  id        String  @id @default(uuid())
  addressId String  @map("address_id")
  userId    String  @map("user_id")
  label     String  @map("label") // e.g. "Kantor Cabang", "Gudang Utama"

  /// RajaOngkir subdistrict ID tujuan (pembeli)
  rajaongkirDestinationId    Int?    @map("rajaongkir_destination_id")
  rajaongkirDestinationLabel String? @db.Text @map("rajaongkir_destination_label")

  isPrimary Boolean @default(false) @map("is_primary")
  address   Address @relation(fields: [addressId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@index([addressId])
  @@index([userId])
  @@map("customer_addresses")
}

// Business placeholders for Address relations
model Partner {
  id        String  @id @default(uuid())
  addressId String  @unique @map("address_id")
  address   Address @relation(fields: [addressId], references: [id])

  @@map("partners")
}

model CompanyProfile {
  id        String  @id @default(uuid())
  addressId String  @unique @map("address_id")
  address   Address @relation(fields: [addressId], references: [id])
}

model ShippingCenter {
  id        String  @id @default(uuid())
  addressId String  @unique @map("address_id")
  address   Address @relation(fields: [addressId], references: [id])

  @@map("shipping_centers")
}

// =========================================================
// FINANCIAL & OPERATIONAL MANAGEMENT
// =========================================================

model PlatformFeeSetting {
  id           String             @id @default(uuid())
  name         PlatformFeeType    @unique
  description  String?            @db.Text @map("description")
  type         FeeCalculationType @default(PERCENTAGE) @map("type")
  amount       Decimal            @db.Decimal(15, 2) @map("amount") // Nominal konstan (5000) atau persentase (2.5)
  isActive     Boolean            @default(true) @map("is_active")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@map("platform_fee_settings")
}


model PaymentChannel {
  id               String            @id @default(uuid())
  name             String            @unique // e.g. "Mandiri Virtual Account"
  code             String            @unique // Xendit channel code e.g. "MANDIRI", "OVO", "QRIS"
  group            PaymentMethod?    @map("group") // e.g. BANK_TRANSFER, E_WALLET, QRIS
  country          String?           @default("ID") @map("country")
  currency         String?           @default("IDR") @map("currency")
  minAmount        Decimal?          @db.Decimal(15, 2) @map("min_amount")
  maxAmount        Decimal?          @db.Decimal(15, 2) @map("max_amount")
  settlementTime   String?           @map("settlement_time")
  xenditType       String?           @map("xendit_type") // Raw type from Xendit CSV
  logoUrl          String?           @db.Text @map("logo_url")
  isActive         Boolean           @default(true) @map("is_active")

  platformAccounts PlatformBankAccount[]
  transactions     Transaction[]

  @@index([country, isActive])
  @@map("payment_channels")
}

model PayoutBank {
  id               String            @id @default(uuid())
  name             String            @unique // e.g. "Bank Mandiri"
  code             String            @unique // Xendit payout channel code e.g. "ID_MANDIRI"
  channelType      String?           @map("channel_type") // Bank | E-Wallet
  country          String?           @default("ID") @map("country")
  currency         String?           @default("IDR") @map("currency")
  minAmount        Decimal?          @db.Decimal(15, 2) @map("min_amount")
  maxAmount        Decimal?          @db.Decimal(15, 2) @map("max_amount")
  flightTime       String?           @map("flight_time")
  logoUrl          String?           @db.Text @map("logo_url")
  isActive         Boolean           @default(true) @map("is_active")

  userPayoutAccounts UserPayoutAccount[]

  @@index([country, isActive])
  @@map("payout_banks")
}

model PlatformBankAccount {
  id               String            @id @default(uuid())
  paymentChannelId String            @map("payment_channel_id")
  accountNumber    String            @map("account_number")
  accountName      String            @map("account_name") // e.g. "PT BISA EKOSISTEM INDONESIA"
  branch           String?           @map("branch")
  isActive         Boolean           @default(true) @map("is_active")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt

  paymentChannel   PaymentChannel    @relation(fields: [paymentChannelId], references: [id], onDelete: Restrict)

  @@map("platform_bank_accounts")
}

model UserPayoutAccount {
  id            String   @id @default(uuid())
  userId        String     @map("user_id")
  bankId        String   @map("bank_id")
  accountNumber String   @map("account_number")
  accountName   String   @map("account_name") // Name as seen on the bank book
  isMain        Boolean  @default(false) @map("is_main")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bank          PayoutBank    @relation(fields: [bankId], references: [id])
  transactions  Transaction[]

  @@unique([userId, accountNumber, bankId])
  @@map("user_payout_accounts")
}

model Wallet {
  id             String        @id @default(uuid())
  userId         String        @unique @map("user_id")
  balance        Decimal       @default(0) @db.Decimal(15, 2) @map("balance") // Current withdrawable balance
  totalEarned    Decimal       @default(0) @db.Decimal(15, 2) @map("total_earned") // Historical total earnings
  totalWithdrawn Decimal       @default(0) @db.Decimal(15, 2) @map("total_withdrawn") // Historical total withdrawals
  updatedAt      DateTime      @updatedAt @map("updated_at")

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model OperatingHour {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")                 // Linked to Supplier/User
  dayOfWeek    Int          @map("day_of_week")             // 0-6 (Sunday to Saturday)
  openTime     String       @map("open_time")               // Opening hour (HH:mm)
  closeTime    String       @map("close_time")              // Closing hour (HH:mm)
  isClosed     Boolean      @default(false) @map("is_closed")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek])
  @@map("operating_hours")
}

model ProductCollection {
  id           String                  @id @default(uuid())
  name         String                  @unique
  slug         String                  @unique
  description  String?                 @db.Text
  thumbnailUrl String?                 @db.Text @map("thumbnail_url")
  isActive     Boolean                 @default(true) @map("is_active")
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")
  products     ProductCollectionItem[]

  @@index([isActive])
  @@index([name])
  @@map("product_collections")
}

model ProductCollectionItem {
  id           String            @id @default(uuid())
  collectionId String            @map("collection_id")
  productId    String            @map("product_id")
  order        Int               @default(0)
  collection   ProductCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@index([collectionId])
  @@index([productId])
  @@map("product_collection_items")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  quantity  Decimal  @db.Decimal(15, 2) @map("quantity")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("cart_items")
}

model ProductLike {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("product_likes")
}

model UserFollow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("FollowingSent", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("FollowingReceived", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("user_follows")
}

/// Kerjasama berlanjut buyer–supplier (Mitra Utama) dengan surat kontrak & e-sign.
model BuyerSupplierPartnership {
  id             String             @id @default(uuid())
  contractNumber String             @unique @map("contract_number")
  buyerId        String             @map("buyer_id")
  supplierId     String             @map("supplier_id")
  tier           PartnershipTier    @default(MAIN_PARTNER) @map("tier")
  status         PartnershipStatus  @default(PENDING) @map("status")

  title                 String
  description           String?  @db.Text
  productCategory       String?  @map("product_category")
  estimatedMonthlyQty   Decimal? @db.Decimal(15, 2) @map("estimated_monthly_qty")
  priceAgreement        String?  @db.Text @map("price_agreement")
  deliveryTerms         String?  @db.Text @map("delivery_terms")
  paymentTerms          String?  @db.Text @map("payment_terms")
  specialTerms          String?  @db.Text @map("special_terms")

  startDate DateTime  @map("start_date")
  endDate   DateTime  @map("end_date")

  buyerSignedAt  DateTime? @map("buyer_signed_at")
  sellerSignedAt DateTime? @map("seller_signed_at")
  /// E-sign pihak penengah BISA (admin platform)
  platformSignedAt  DateTime? @map("platform_signed_at")
  buyerSignHash  String?   @map("buyer_sign_hash")
  sellerSignHash String?   @map("seller_sign_hash")
  platformSignHash String? @map("platform_sign_hash")
  platformSignerId String? @map("platform_signer_id")
  /// Snapshot identitas penandatangan (nama, jabatan, perusahaan)
  buyerSignerName    String? @map("buyer_signer_name")
  buyerSignerTitle   String? @map("buyer_signer_title")
  buyerCompanyName   String? @map("buyer_company_name")
  sellerSignerName   String? @map("seller_signer_name")
  sellerSignerTitle  String? @map("seller_signer_title")
  sellerCompanyName  String? @map("seller_company_name")
  platformSignerName  String? @map("platform_signer_name")
  platformSignerTitle String? @map("platform_signer_title")
  isFullySigned  Boolean   @default(false) @map("is_fully_signed")

  /// Perpanjangan kontrak
  renewalCount           Int       @default(0) @map("renewal_count")
  renewalProposedEndDate DateTime? @map("renewal_proposed_end_date")
  renewalRequestedBy     String?   @map("renewal_requested_by")
  renewalRequestedAt     DateTime? @map("renewal_requested_at")
  renewalNote            String?   @db.Text @map("renewal_note")
  renewedFromId          String?   @map("renewed_from_id")

  originatingNegotiationId String? @map("originating_negotiation_id")
  originatingOrderId       String? @map("originating_order_id")
  initiatedBy              String  @map("initiated_by")
  rejectionReason          String? @db.Text @map("rejection_reason")
  terminatedAt             DateTime? @map("terminated_at")
  terminatedBy             String?   @map("terminated_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  buyer    User @relation("BuyerPartnerships", fields: [buyerId], references: [id], onDelete: Restrict)
  supplier User @relation("SupplierPartnerships", fields: [supplierId], references: [id], onDelete: Restrict)

  @@index([buyerId])
  @@index([supplierId])
  @@index([status])
  @@index([buyerId, supplierId])
  @@map("buyer_supplier_partnerships")
}

model MediaUploadSession {
  id             String                   @id @default(uuid())
  userId         String                   @map("user_id")
  folder         String
  fileName       String                   @map("file_name")
  mimeType       String                   @map("mime_type")
  totalBytes     BigInt                   @map("total_bytes")
  partSize       Int                      @map("part_size")
  totalParts     Int                      @map("total_parts")
  r2UploadId     String?                  @map("r2_upload_id")
  r2Key          String                   @map("r2_key")
  status         MediaUploadSessionStatus @default(INIT)
  completedParts Json?                    @map("completed_parts")
  finalPath      String?                  @map("final_path") @db.Text
  expiresAt      DateTime                 @map("expires_at")
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@map("media_upload_sessions")
}

// =========================================================
// BISA Express — internal courier
// =========================================================

model BisaExpressDriver {
  id             String            @id @default(uuid())
  userId         String            @unique @map("user_id")
  employeeCode   String            @unique @map("employee_code")
  status         DriverStatus      @default(AVAILABLE)
  vehicleType    DriverVehicleType @default(PICKUP_TRUCK)
  vehiclePlate   String?           @map("vehicle_plate")
  maxCapacityKg  Decimal           @db.Decimal(10, 2) @default(1000) @map("max_capacity_kg")
  homeHubId      String?           @map("home_hub_id")
  currentLat     Decimal?          @db.Decimal(10, 8) @map("current_lat")
  currentLng     Decimal?          @db.Decimal(11, 8) @map("current_lng")
  lastLocationAt DateTime?         @map("last_location_at")
  totalDeliveries Int              @default(0) @map("total_deliveries")
  totalPickups   Int               @default(0) @map("total_pickups")
  avgRating      Decimal           @db.Decimal(3, 2) @default(0) @map("avg_rating")
  isActive       Boolean           @default(true) @map("is_active")
  joinedAt       DateTime          @default(now()) @map("joined_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeHub      BisaExpressHub?      @relation(fields: [homeHubId], references: [id], onDelete: SetNull)
  shipments    BisaExpressShipment[] @relation("PickupDriver")
  deliveries   BisaExpressShipment[] @relation("DeliveryDriver")
  locationLogs DriverLocationLog[]
  attempts     DeliveryAttempt[]

  @@index([status])
  @@index([homeHubId])
  @@index([isActive, status])
  @@map("bisa_express_drivers")
}

model DriverLocationLog {
  id         String   @id @default(uuid())
  driverId   String   @map("driver_id")
  latitude   Decimal  @db.Decimal(10, 8)
  longitude  Decimal  @db.Decimal(11, 8)
  speed      Decimal? @db.Decimal(6, 2)
  heading    Decimal? @db.Decimal(5, 2)
  accuracy   Decimal? @db.Decimal(8, 2)
  capturedAt DateTime @default(now()) @map("captured_at")

  driver BisaExpressDriver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId, capturedAt])
  @@map("driver_location_logs")
}

model BisaExpressHub {
  id                 String   @id @default(uuid())
  code               String   @unique
  name               String
  type               HubType  @default(MAIN_HUB)
  addressId          String   @map("address_id")
  coverageProvinces  Json?    @map("coverage_provinces")
  coverageRegencies  Json?    @map("coverage_regencies")
  contactPhone       String?  @map("contact_phone")
  contactName        String?  @map("contact_name")
  operatingHours     String?  @map("operating_hours")
  maxDailyCapacity   Int?     @map("max_daily_capacity")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  address              Address               @relation(fields: [addressId], references: [id])
  drivers              BisaExpressDriver[]
  originShipments      BisaExpressShipment[] @relation("OriginHub")
  destinationShipments BisaExpressShipment[] @relation("DestinationHub")
  hubLogs              ShipmentHubLog[]

  @@index([type, isActive])
  @@map("bisa_express_hubs")
}

model BisaExpressShipment {
  id                String            @id @default(uuid())
  orderId           String            @unique @map("order_id")
  awbNumber         String            @unique @map("awb_number")
  status            BisaExpressStatus @default(AWAITING_PICKUP)
  originHubId       String?           @map("origin_hub_id")
  destinationHubId  String?           @map("destination_hub_id")
  pickupAddress     String            @db.Text @map("pickup_address")
  pickupContact     String            @map("pickup_contact")
  pickupPhone       String            @map("pickup_phone")
  pickupLat         Decimal?          @db.Decimal(10, 8) @map("pickup_lat")
  pickupLng         Decimal?          @db.Decimal(11, 8) @map("pickup_lng")
  pickupDriverId    String?           @map("pickup_driver_id")
  pickupScheduledAt DateTime?         @map("pickup_scheduled_at")
  pickedUpAt        DateTime?         @map("picked_up_at")
  deliveryAddress   String            @db.Text @map("delivery_address")
  deliveryContact   String            @map("delivery_contact")
  deliveryPhone     String            @map("delivery_phone")
  deliveryLat       Decimal?          @db.Decimal(10, 8) @map("delivery_lat")
  deliveryLng       Decimal?          @db.Decimal(11, 8) @map("delivery_lng")
  deliveryDriverId  String?           @map("delivery_driver_id")
  deliveredAt       DateTime?         @map("delivered_at")
  /// Berat dalam UnitStatus produk (KG/TON) — bukan gram
  weight            Decimal           @db.Decimal(15, 3) @map("weight")
  weightUnit        UnitStatus        @default(KG) @map("weight_unit")
  lengthCm          Int?              @map("length_cm")
  widthCm           Int?              @map("width_cm")
  heightCm          Int?              @map("height_cm")
  itemDescription   String?           @db.Text @map("item_description")
  packageCount      Int               @default(1) @map("package_count")
  shippingCost      Decimal           @db.Decimal(15, 2) @map("shipping_cost")
  insuranceCost     Decimal           @db.Decimal(15, 2) @default(0) @map("insurance_cost")
  codAmount         Decimal           @db.Decimal(15, 2) @default(0) @map("cod_amount")
  serviceType       String            @map("service_type")
  etdDays           Int?              @map("etd_days")
  podPhotoUrl       String?           @db.Text @map("pod_photo_url")
  podSignatureUrl   String?           @db.Text @map("pod_signature_url")
  podReceivedBy     String?           @map("pod_received_by")
  podNote           String?           @db.Text @map("pod_note")
  sellerNote        String?           @db.Text @map("seller_note")
  driverNote        String?           @db.Text @map("driver_note")
  failReason        String?           @db.Text @map("fail_reason")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  order          Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  originHub      BisaExpressHub?       @relation("OriginHub", fields: [originHubId], references: [id])
  destinationHub BisaExpressHub?       @relation("DestinationHub", fields: [destinationHubId], references: [id])
  pickupDriver   BisaExpressDriver?    @relation("PickupDriver", fields: [pickupDriverId], references: [id])
  deliveryDriver BisaExpressDriver?    @relation("DeliveryDriver", fields: [deliveryDriverId], references: [id])
  statusLogs     ShipmentStatusLog[]
  hubLogs        ShipmentHubLog[]
  attempts       DeliveryAttempt[]

  @@index([status])
  @@index([awbNumber])
  @@index([pickupDriverId])
  @@index([deliveryDriverId])
  @@index([createdAt])
  @@map("bisa_express_shipments")
}

model ShipmentStatusLog {
  id          String            @id @default(uuid())
  shipmentId  String            @map("shipment_id")
  status      BisaExpressStatus
  description String            @db.Text
  latitude    Decimal?          @db.Decimal(10, 8)
  longitude   Decimal?          @db.Decimal(11, 8)
  location    String?
  actorId     String?           @map("actor_id")
  actorType   String?           @map("actor_type")
  photoUrl    String?           @db.Text @map("photo_url")
  createdAt   DateTime          @default(now()) @map("created_at")

  shipment BisaExpressShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, createdAt])
  @@map("shipment_status_logs")
}

model ShipmentHubLog {
  id        String   @id @default(uuid())
  shipmentId String  @map("shipment_id")
  hubId     String   @map("hub_id")
  action    String
  note      String?  @db.Text
  scannedBy String?  @map("scanned_by")
  createdAt DateTime @default(now()) @map("created_at")

  shipment BisaExpressShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  hub      BisaExpressHub      @relation(fields: [hubId], references: [id])

  @@index([shipmentId])
  @@index([hubId, createdAt])
  @@map("shipment_hub_logs")
}

model DeliveryAttempt {
  id            String                @id @default(uuid())
  shipmentId    String                @map("shipment_id")
  driverId      String                @map("driver_id")
  attemptNumber Int                   @map("attempt_number")
  result        DeliveryAttemptResult
  note          String?               @db.Text
  photoUrl      String?               @db.Text @map("photo_url")
  latitude      Decimal?              @db.Decimal(10, 8)
  longitude     Decimal?              @db.Decimal(11, 8)
  attemptedAt   DateTime              @default(now()) @map("attempted_at")

  shipment BisaExpressShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  driver   BisaExpressDriver   @relation(fields: [driverId], references: [id])

  @@index([shipmentId])
  @@map("delivery_attempts")
}

model BisaExpressRate {
  id              String     @id @default(uuid())
  originZone      String     @map("origin_zone")
  destinationZone String     @map("destination_zone")
  serviceType     String     @map("service_type")
  /// Batas berat dalam weightUnit (UnitStatus KG/TON)
  minWeight       Decimal    @default(0) @db.Decimal(15, 3) @map("min_weight")
  maxWeight       Decimal    @default(999999999) @db.Decimal(15, 3) @map("max_weight")
  baseCost        Decimal    @db.Decimal(15, 2) @map("base_cost")
  /// Biaya per satuan — satuan = weightUnit (selaras UnitStatus produk)
  perUnitCost     Decimal    @db.Decimal(15, 2) @map("per_unit_cost")
  weightUnit      UnitStatus @default(KG) @map("weight_unit")
  etdDays         Int        @map("etd_days")
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@unique([originZone, destinationZone, serviceType, minWeight, weightUnit], map: "bisa_express_rates_zone_svc_min_u_key")
  @@index([originZone, destinationZone], map: "bisa_express_rates_origin_destination_idx")
  @@map("bisa_express_rates")
}

model BisaExpressCoverage {
  id         String  @id @default(uuid())
  provinceId String  @map("province_id")
  regencyId  String? @map("regency_id")
  zone       String
  isPickup   Boolean @default(true) @map("is_pickup")
  isDelivery Boolean @default(true) @map("is_delivery")
  isActive   Boolean @default(true) @map("is_active")

  @@unique([provinceId, regencyId])
  @@index([zone])
  @@map("bisa_express_coverage")
}

/// Aturan layanan vs berat — dikelola admin (bukan hardcode di constants).
model BisaExpressServiceRule {
  id              String     @id @default(uuid())
  serviceType     String     @unique @map("service_type")
  label           String?
  minWeight       Decimal    @default(0) @db.Decimal(15, 3) @map("min_weight")
  maxWeight       Decimal    @default(999999999) @db.Decimal(15, 3) @map("max_weight")
  weightUnit      UnitStatus @default(KG) @map("weight_unit")
  /// true = selalu boleh dipilih (mis. VIP), meski di luar band berat normal
  alwaysAvailable Boolean    @default(false) @map("always_available")
  isActive        Boolean    @default(true) @map("is_active")
  sortOrder       Int        @default(0) @map("sort_order")
  note            String?    @db.Text
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("bisa_express_service_rules")
}
