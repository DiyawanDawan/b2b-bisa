// =========================================================
// AUTH & USERS
// =========================================================

model User {
  id                 String             @id @default(uuid())
  email              String             @unique
  phone              String?            @unique
  password           String?
  fullName           String     @map("full_name")
  role               UserRole   @map("role")        @default(SUPPLIER)
  isEmailVerified    Boolean    @map("is_email_verified") @default(false)
  isPhoneVerified    Boolean    @map("is_phone_verified") @default(false)
  firebaseUid        String?    @map("firebase_uid") @unique
  avatarUrl          String?    @map("avatar_url") @db.Text
  province           String?    @map("province") // Lokasi user untuk GIS matching
  regency            String?    @map("regency")            // Kabupaten

  // Enterprise Profile (from Account Settings UI)
  jobTitle           String?    @map("job_title")            // e.g. "Procurement Manager"
  region             String?    @map("region")            // e.g. "East Java, Indonesia"
  preferredLanguage  String?    @map("preferred_language") @default("Bahasa Indonesia")

  // Settings & Security
  enableNotifications Boolean    @map("enable_notifications") @default(true)
  enable2FA           Boolean    @map("enable_2fa") @default(false)
  isPublicInMarketplace Boolean    @map("is_public_in_marketplace") @default(true)

  // Impact Stats (Cached)
  esgScore           Decimal    @map("esg_score") @db.Decimal(15, 2) @default(0)
  greenRank          String?    @map("green_rank") @default("Seedling")

  // Subscription Details (IoT Pro Feature)
  tier               UserTier           @default(FREE)
  subscriptionExpiresAt DateTime? @map("subscription_expires_at")

  // FB-19 display currency preference (checkout tetap IDR)
  displayCurrency    String             @default("IDR") @map("display_currency")

  // FB-20 referral program
  referralCode       String?            @unique @map("referral_code")
  referredById       String?            @map("referred_by_id")
  referredBy         User?              @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals          User[]             @relation("UserReferrals")

  status             UserStatus         @default(ACTIVE) @map("status")
  createdAt          DateTime           @default(now())  @map("created_at")
  updatedAt          DateTime @map("updated_at")           @updatedAt

  addressId          String? @map("address_id")
  address            Address?           @relation(fields: [addressId], references: [id], onDelete: SetNull)

  profile            UserProfile?
  tokens             Token[]
  verification       UserVerification?
  products           Product[]
  ordersAsBuyer      Order[]            @relation("BuyerOrders")
  ordersAsSeller     Order[]            @relation("SellerOrders")
  transactions       Transaction[]
  iotDevices         IotDevice[]
  forumPosts         ForumPost[]
  forumComments      ForumComment[]
  ownedForumGroups   ForumGroup[]       @relation("ForumGroupOwner")
  forumGroupMembers  ForumGroupMember[]
  notifications      Notification[]
  aiPredictions      AIPrediction[]
  knowledgeDocuments KnowledgeDocument[] @relation("KnowledgeUploadedBy")
  documents          UserDocument[]
  chatMessages       ChatMessage[]
  forumVotes         ForumVote[]
  customerAddresses  CustomerAddress[]
  payoutAccounts     UserPayoutAccount[]
  mediaUploadSessions MediaUploadSession[]
  wallet             Wallet?
  operatingHours     OperatingHour[]
  givenReviews       Review[]           @relation("GivenReviews")
  productQuestionsAsked ProductQuestion[] @relation("ProductQuestionsAsked")
  productQuestionsAnswered ProductQuestion[] @relation("ProductQuestionsAnswered")
  articles           Article[]
  auditLogs          AuditLog[]
  buyerNegotiations  Negotiation[]      @relation("BuyerNegotiations")
  sellerNegotiations Negotiation[]      @relation("SellerNegotiations")
  devices           UserDevice[]
  cartItems         CartItem[]
  productLikes      ProductLike[]
  followingSent     UserFollow[] @relation("FollowingSent")
  followingReceived UserFollow[] @relation("FollowingReceived")
  storeBanners      StoreBanner[]
  disputesRaised    OrderDispute[]     @relation("DisputesRaised")
  rfqsCreated       Rfq[]              @relation("BuyerRfqs")
  rfqResponses      RfqResponse[]
  voucherRedemptions VoucherRedemption[]
  savedPayments     UserSavedPayment[]
  supplierVouchers  Voucher[]          @relation("SupplierVouchers")
  referralRewardsEarned ReferralReward[] @relation("ReferrerRewards")
  referralRewardAsReferred ReferralReward? @relation("ReferredUserReward")
  supplierApiKeys   SupplierApiKey[]
  liveSessions      LiveSession[]
  liveSessionComments LiveSessionComment[]
  buyerPartnerships BuyerSupplierPartnership[] @relation("BuyerPartnerships")
  supplierPartnerships BuyerSupplierPartnership[] @relation("SupplierPartnerships")
  buyerBookings     Booking[] @relation("BuyerBookings")
  supplierBookings  Booking[] @relation("SupplierBookings")
  supportTickets    SupportTicket[] @relation("SupportTicketOwner")
  assignedSupportTickets SupportTicket[] @relation("SupportTicketAssignee")
  supportMessages   SupportMessage[] @relation("SupportMessageSender")
  bisaExpressDriver BisaExpressDriver?

  @@index([role])
  @@index([referralCode])
  @@index([referredById])
  @@index([status])
  @@index([createdAt])
  @@index([isPublicInMarketplace])
  @@index([province, regency])
  @@index([fullName])
  @@map("users")
}

model UserProfile {
  id           String  @id @default(uuid())
  userId       String  @map("user_id") @unique
  bio          String? @db.Text
  website      String?
  // Business info for Suppliers/Buyers
  companyName  String? @map("company_name")
  npwp         String?
  businessType String? @map("business_type")   // e.g. "Pengepul", "Distributor", "Industri Biochar"

  /// RajaOngkir subdistrict ID asal pengiriman (supplier)
  rajaongkirOriginId    Int?    @map("rajaongkir_origin_id")
  rajaongkirOriginLabel String? @db.Text @map("rajaongkir_origin_label")

  addressId    String? @map("address_id") @unique
  address      Address?  @relation(fields: [addressId], references: [id], onDelete: SetNull)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model StoreBanner {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  imageUrl  String   @db.Text @map("image_url")
  title     String?  @map("title")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@map("store_banners")
}

model Token {
  id        String    @id @default(uuid())
  userId    String @map("user_id")
  token     String    @db.Text
  type      TokenType
  expiresAt DateTime @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token(length: 191)])
  @@index([userId, type])
  @@map("tokens")
}

model UserVerification {
  id             String              @id @default(uuid())
  userId         String @map("user_id")           @unique
  ktpUrl         String? @db.Text @map("ktp_url")
  selfieUrl      String? @db.Text @map("selfie_url")
  businessName    String? @map("business_name")
  taxId           String? @map("tax_id")                      // NPWP / Tax ID for Invoices
  businessAddress String? @db.Text @map("business_address")
  verificationStatus VerificationStatus @default(PENDING)
  nibUrl          String? @db.Text @map("nib_url")         // Business Registration Number
  siupUrl         String? @db.Text @map("siup_url")         // Trade License
  isVerified      Boolean @default(false)
  reviewedBy     String? @map("reviewed_by")
  reviewedAt     DateTime? @map("reviewed_at")
  rejectionReason String? @db.Text @map("rejection_reason")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([verificationStatus])
  @@index([createdAt])
  @@map("user_verifications")
}

model UserDocument {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  title       String   @map("title")             // e.g. "VAT_Report_Q3_2023.pdf"
  fileUrl     String   @db.Text @map("file_url")
  fileType    String   @map("file_type")             // e.g. "TAX_REPORT", "IDENTITY", "CERTIFICATE"
  fileSize    String?  @map("file_size")            // e.g. "1.2 MB"
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_documents")
}

// =========================================================

enum CATEGORY_TYPE {
  PRODUK
  FORUM
  ARTICLE
}

// =========================================================
// MARKETPLACE B2B - Biomassa & Biochar Products
// =========================================================

model Category {
  id          String    @id @default(uuid())
  name        String    @unique    // e.g. "Limbah Biomassa", "Produk Biochar"
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  categoryType CATEGORY_TYPE @map("category_type")
  productMode  ProductMode?  @map("product_mode") // Separates Biomass vs Organic categories
  biomassaType BiomassaType? @map("biomassa_type") // Required filter for BIOMASS_MATERIAL shelf

  products    Product[]
  articles    Article[]
  forumPosts  ForumPost[]
  rfqs        Rfq[]

  @@index([name])
  @@index([categoryType])
  @@index([productMode])
  @@index([productMode, biomassaType])
  @@map("categories")
}

enum ProductStatus {
  ACTIVE
  DRAFT
  INACTIVE
  BLOCKED
  OUT_OF_STOCK
  DELETED
}

enum HarvestLotStatus {
  SCHEDULED
  HARVESTING
  HARVESTED
  STOCKED
  CANCELLED
  EXPIRED
}

enum ProductAvailabilityType {
  READY
  PRE_HARVEST
  MIXED
}

enum UnitStatus {
  KG
  TON
}

model Product {
  id            String       @id @default(uuid())
  userId        String                       // SUPPLIER who lists the product
  categoryId    String? @map("category_id")
  name          String                       // e.g. "Sekam Padi Kering Grade A"
  biomassaType  BiomassaType               @map("biomassa_type")  // SEKAM_PADI, TONGKOL_JAGUNG, etc.
  grade         BiocharGrade?              @map("grade")  // Only for BIOCHAR type
  description   String?      @db.Text
  pricePerUnit  Decimal      @db.Decimal(15, 2) @map("price_per_unit")
  originalPrice Decimal?     @db.Decimal(15, 2) @map("original_price") // Harga sebelum diskon (nullable)
  stock         Decimal      @db.Decimal(15, 2) @map("stock") // Changed from Int to support decimal weights (e.g. 1.5 Ton)
  reservedStock Decimal      @db.Decimal(15, 2) @default(0) @map("reserved_stock")
  unit          UnitStatus                   @map("unit") // Unit of stock (KG/TON)
  minOrder      Decimal      @db.Decimal(15, 2) @default(100) @map("min_order") // Changed from Int
  allowsSample  Boolean      @default(true) @map("allows_sample")
  sampleMaxQty  Decimal      @db.Decimal(15, 2) @default(1) @map("sample_max_qty")
  samplePricePerUnit Decimal? @db.Decimal(15, 2) @map("sample_price_per_unit")

  // Organic Produce Mode fields
  productMode    ProductMode @default(BIOMASS_MATERIAL) @map("product_mode")
  fertilizerType String?     @map("fertilizer_type")
  isChemicalFree Boolean     @default(false) @map("is_chemical_free")
  cropType       String?     @map("crop_type")
  availabilityType ProductAvailabilityType @default(READY) @map("availability_type")
  nextHarvestDate DateTime?  @map("next_harvest_date")
  nextHarvestQtyTon Decimal? @db.Decimal(15, 2) @map("next_harvest_qty_ton")

  province      String?                      @map("province") // Location for GIS matching
  regency       String?                      @map("regency")
  thumbnailUrl  String?      @db.Text @map("thumbnail_url")
  status        ProductStatus @default(ACTIVE) @map("status")
  isCertified   Boolean       @default(false)  @map("is_certified") // Verified quality product
  isIotMonitored Boolean     @default(false) @map("is_iot_monitored")
  isEscrowProtected Boolean  @default(true) @map("is_escrow_protected")

  // Cache fields for performance
  averageRating Decimal      @db.Decimal(3, 2) @default(0) @map("average_rating")
  totalReviews  Int          @default(0) @map("total_reviews")
  totalSold     Int          @default(0) @map("total_sold")
  viewCount     Int          @default(0) @map("view_count")

  // Sponsored listing (FB-16)
  isPromoted        Boolean   @default(false) @map("is_promoted")
  promotedUntil     DateTime? @map("promoted_until")
  promoImpressions  Int       @default(0) @map("promo_impressions")
  promoClicks       Int       @default(0) @map("promo_clicks")

  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  user          User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  category      Category?    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  technicalSpec ProductTechnicalSpec?
  orderItems    OrderItem[]
  negotiations  Negotiation[]
  reviews       Review[]
  images        ProductImage[]
  video         ProductVideo?
  collections   ProductCollectionItem[]
  cartItems     CartItem[]
  productLikes  ProductLike[]
  specs         ProductSpec[]
  questions     ProductQuestion[]
  harvestLots   ProductHarvestLot[]
  bookings      Booking[]

  @@index([userId])
  @@index([categoryId])
  @@index([biomassaType])
  @@index([status])
  @@index([totalSold])  
  @@index([createdAt])
  @@index([province, regency])
  @@index([name])
  @@index([productMode])
  @@index([cropType])
  @@index([availabilityType])
  @@index([nextHarvestDate])
  @@index([isPromoted, promotedUntil])
  @@map("products")
}

model ProductHarvestLot {
  id                  String           @id @default(uuid())
  productId           String           @map("product_id")
  seasonLabel         String?          @map("season_label")
  expectedHarvestDate DateTime         @map("expected_harvest_date")
  expectedQuantityTon Decimal          @db.Decimal(15, 2) @map("expected_quantity_ton")
  reservedQuantityTon Decimal          @db.Decimal(15, 2) @default(0) @map("reserved_quantity_ton")
  actualHarvestDate   DateTime?        @map("actual_harvest_date")
  actualQuantityTon   Decimal?         @db.Decimal(15, 2) @map("actual_quantity_ton")
  status              HarvestLotStatus @default(SCHEDULED) @map("status")
  notes               String?          @db.Text
  stockedAt           DateTime?        @map("stocked_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([productId, expectedHarvestDate])
  @@index([status, expectedHarvestDate])
  @@map("product_harvest_lots")
}

model Booking {
  id                   String        @id @default(uuid())
  bookingNumber        String        @unique @map("booking_number")
  buyerId              String        @map("buyer_id")
  supplierId           String        @map("supplier_id")
  productId            String        @map("product_id")
  harvestLotId         String?       @map("harvest_lot_id")
  productMode          ProductMode   @map("product_mode")
  quantity             Decimal       @db.Decimal(15, 2)
  unit                 UnitStatus
  priceSnapshot        Decimal       @db.Decimal(15, 2) @map("price_snapshot")
  subtotalSnapshot     Decimal       @db.Decimal(15, 2) @map("subtotal_snapshot")
  status               BookingStatus @default(PENDING_PAYMENT)
  expiresAt            DateTime      @map("expires_at")
  expectedDeliveryDate DateTime?     @map("expected_delivery_date")
  notes                String?       @db.Text
  orderId              String?       @unique @map("order_id")
  cancelledById        String?       @map("cancelled_by_id")
  cancelReason         String?       @db.Text @map("cancel_reason")
  confirmedAt          DateTime?     @map("confirmed_at")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  buyer      User               @relation("BuyerBookings", fields: [buyerId], references: [id], onDelete: Restrict)
  supplier   User               @relation("SupplierBookings", fields: [supplierId], references: [id], onDelete: Restrict)
  product    Product            @relation(fields: [productId], references: [id], onDelete: Restrict)
  harvestLot ProductHarvestLot? @relation(fields: [harvestLotId], references: [id], onDelete: SetNull)
  order      Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([buyerId, status])
  @@index([supplierId, status])
  @@index([productId])
  @@index([status, expiresAt])
  @@map("bookings")
}

model ProductTechnicalSpec {
  id            String   @id @default(uuid())
  productId     String   @unique @map("product_id")

  // Technical Specs
  carbonPurity        Decimal? @db.Decimal(5, 2) @map("carbon_purity") // % Carbon Purity
  moistureContent     Decimal? @db.Decimal(5, 2) @map("moisture_content") // % Moisture
  surfaceArea         Decimal? @db.Decimal(10, 2) @map("surface_area") // m2/g
  phLevel             Decimal? @db.Decimal(4, 2) @map("ph_level")
  density             String?                   @map("density") // e.g. "95-105 kg/m3"
  productionCapacity  Decimal? @db.Decimal(15, 2) @map("production_capacity") // Monthly capacity Ton
  carbonOffsetPerTon  Decimal? @db.Decimal(10, 2) @map("carbon_offset_per_ton") // tCO2e offset contribution

  // Packaging & Logistics
  grossWeightPerSak   Decimal? @db.Decimal(10, 2)  @map("gross_weight_per_sak") // kg
  netWeightPerSak     Decimal? @db.Decimal(10, 2) @map("net_weight_per_sak") // kg
  bagDimension        String?                   @map("bag_dimension") // e.g. "115x75 cm"
  heavyMetals         Json?                     @map("heavy_metals") // { "As": 10, "Hg": 1, ... }

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
