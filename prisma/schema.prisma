generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// =========================================================
// ENUMS - aligned to BISA B2B Proposal
// =========================================================

// FeeCalculationType moved below to consolidated enums block

enum UserRole {
  SUPPLIER
  BUYER
  ADMIN
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum UserStatus {
  ACTIVE
  BLOCKED
  INACTIVE
  DELETED
}

enum TokenType {
  REFRESH
  RESET_PASSWORD
  EMAIL_VERIFICATION
  PHONE_OTP
}

// BiomassaType and BiocharGrade moved below to consolidated enums block

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
}

enum TransactionStatus {
  PENDING
  ESCROW_HELD
  RELEASED
  REFUNDED
  FAILED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

enum PaymentMethod {
  BANK_TRANSFER
  E_WALLET
  QRIS
  CREDIT_CARD
  CASH
}

enum TransactionType {
  SALES
  PAYOUT
  REFUND
  PLATFORM_FEE
  SUBSCRIPTION
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum NotificationType {
  ORDER_STATUS
  PAYMENT_RECEIVED
  IOT_ALERT
  SYSTEM_ANNOUNCEMENT
  DISPUTE
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
  IOT_HARDWARE
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum PostStatus {
  PUBLISHED
  DRAFT
  ARCHIVED
}

enum UserTier {
  FREE
  PRO
}

enum VillageType {
  KELURAHAN
  DESA
}

enum VoteType {
  UP
  DOWN
}

enum TrendType {
  UP
  DOWN
  STABLE
}

enum TrendCategory {
  CARBON
  LOGISTICS
  BIOMASSA
}

enum BiomassaType {
  BIOCHAR
  SEKAM_PADI
  TONGKOL_JAGUNG
  TEMPURUNG_KELAPA
  WOOD_CHIP
  OTHER
}

enum ProductMode {
  BIOMASS_MATERIAL
  ORGANIC_PRODUCE
}

enum BiocharGrade {
  A
  B
  C
}

enum FeeCalculationType {
  PERCENTAGE
  FIXED
}

enum PlatformFeeType {
  TRANSACTION_FEE
  WITHDRAWAL_FEE
  ADMIN_FEE
  LOGISTICS_FEE
  CARBON_FEE
  BIOMASS_FEE
  SUBSCRIPTION
  VAT
}

enum ShipmentType {
  SEA_FREIGHT
  LAND_CARGO
  AIR_FREIGHT
}

enum VesselType {
  CARGO_SHIP
  BARGE
  TRUCK_CARGO
  PLANE_CARGO
  OTHER
}

enum PackagingType {
  ECO_SACK
  JUMBO_BAG
  BULK
  OTHER
}

enum NegotiationStatus {
    OPEN_NEGOTIATION
    OFFER_SUBMITTED
    OFFER_ACCEPTED
    OFFER_REJECTED
    EXPIRED
    LOCKED
    CANCELLED
  }

/// Chat tanya produk vs negosiasi harga (ruang terpisah per buyer–produk).
enum NegotiationRoomType {
  INQUIRY
  NEGOTIATION
}

enum TaxStatus {
  INCLUDED
  EXCLUDED
}

enum IoTAlertType {
  OVERHEATING
  TEMP_TOO_LOW
  OFFLINE
  SENSOR_FAILURE
  OTHER
}


// =========================================================
// AUTH & USERS
// =========================================================

model User {
  id                 String             @id @default(uuid())
  email              String             @unique
  phone              String?            @unique
  password           String?
  fullName           String     @map("full_name")
  role               UserRole   @map("role")        @default(SUPPLIER)
  isEmailVerified    Boolean    @map("is_email_verified") @default(false)
  isPhoneVerified    Boolean    @map("is_phone_verified") @default(false)
  firebaseUid        String?    @map("firebase_uid") @unique
  avatarUrl          String?    @map("avatar_url") @db.Text
  province           String?    @map("province") // Lokasi user untuk GIS matching
  regency            String?    @map("regency")            // Kabupaten

  // Enterprise Profile (from Account Settings UI)
  jobTitle           String?    @map("job_title")            // e.g. "Procurement Manager"
  region             String?    @map("region")            // e.g. "East Java, Indonesia"
  preferredLanguage  String?    @map("preferred_language") @default("Bahasa Indonesia")

  // Settings & Security
  enableNotifications Boolean    @map("enable_notifications") @default(true)
  enable2FA           Boolean    @map("enable_2fa") @default(false)
  isPublicInMarketplace Boolean    @map("is_public_in_marketplace") @default(true)

  // Impact Stats (Cached)
  esgScore           Decimal    @map("esg_score") @db.Decimal(15, 2) @default(0)
  greenRank          String?    @map("green_rank") @default("Seedling")

  // Subscription Details (IoT Pro Feature)
  tier               UserTier           @default(FREE)
  subscriptionExpiresAt DateTime? @map("subscription_expires_at")

  status             UserStatus         @default(ACTIVE) @map("status")
  createdAt          DateTime           @default(now())  @map("created_at")
  updatedAt          DateTime @map("updated_at")           @updatedAt

  addressId          String? @map("address_id")
  address            Address?           @relation(fields: [addressId], references: [id], onDelete: SetNull)

  profile            UserProfile?
  tokens             Token[]
  verification       UserVerification?
  products           Product[]
  ordersAsBuyer      Order[]            @relation("BuyerOrders")
  ordersAsSeller     Order[]            @relation("SellerOrders")
  transactions       Transaction[]
  iotDevices         IotDevice[]
  forumPosts         ForumPost[]
  forumComments      ForumComment[]
  notifications      Notification[]
  aiPredictions      AIPrediction[]
  documents          UserDocument[]
  chatMessages       ChatMessage[]
  forumVotes         ForumVote[]
  customerAddresses  CustomerAddress[]
  payoutAccounts     UserPayoutAccount[]
  wallet             Wallet?
  operatingHours     OperatingHour[]
  givenReviews       Review[]           @relation("GivenReviews")
  articles           Article[]
  auditLogs          AuditLog[]
  buyerNegotiations  Negotiation[]      @relation("BuyerNegotiations")
  sellerNegotiations Negotiation[]      @relation("SellerNegotiations")
  devices           UserDevice[]
  cartItems         CartItem[]
  productLikes      ProductLike[]
  followingSent     UserFollow[] @relation("FollowingSent")
  followingReceived UserFollow[] @relation("FollowingReceived")
  storeBanners      StoreBanner[]
  disputesRaised    OrderDispute[]     @relation("DisputesRaised")

  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@index([isPublicInMarketplace])
  @@index([province, regency])
  @@index([fullName])
  @@map("users")
}

model UserProfile {
  id           String  @id @default(uuid())
  userId       String  @map("user_id") @unique
  bio          String? @db.Text
  website      String?
  // Business info for Suppliers/Buyers
  companyName  String? @map("company_name")
  npwp         String?
  businessType String? @map("business_type")   // e.g. "Pengepul", "Distributor", "Industri Biochar"

  /// RajaOngkir subdistrict ID asal pengiriman (supplier)
  rajaongkirOriginId    Int?    @map("rajaongkir_origin_id")
  rajaongkirOriginLabel String? @db.Text @map("rajaongkir_origin_label")

  addressId    String? @map("address_id") @unique
  address      Address?  @relation(fields: [addressId], references: [id], onDelete: SetNull)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model StoreBanner {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  imageUrl  String   @db.Text @map("image_url")
  title     String?  @map("title")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@map("store_banners")
}

model Token {
  id        String    @id @default(uuid())
  userId    String @map("user_id")
  token     String    @db.Text
  type      TokenType
  expiresAt DateTime @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token(length: 191)])
  @@index([userId, type])
  @@map("tokens")
}

model UserVerification {
  id             String              @id @default(uuid())
  userId         String @map("user_id")           @unique
  ktpUrl         String? @db.Text @map("ktp_url")
  selfieUrl      String? @db.Text @map("selfie_url")
  businessName    String? @map("business_name")
  taxId           String? @map("tax_id")                      // NPWP / Tax ID for Invoices
  businessAddress String? @db.Text @map("business_address")
  verificationStatus VerificationStatus @default(PENDING)
  nibUrl          String? @db.Text @map("nib_url")         // Business Registration Number
  siupUrl         String? @db.Text @map("siup_url")         // Trade License
  isVerified      Boolean @default(false)
  reviewedBy     String? @map("reviewed_by")
  reviewedAt     DateTime? @map("reviewed_at")
  rejectionReason String? @db.Text @map("rejection_reason")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([verificationStatus])
  @@index([createdAt])
  @@map("user_verifications")
}

model UserDocument {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  title       String   @map("title")             // e.g. "VAT_Report_Q3_2023.pdf"
  fileUrl     String   @db.Text @map("file_url")
  fileType    String   @map("file_type")             // e.g. "TAX_REPORT", "IDENTITY", "CERTIFICATE"
  fileSize    String?  @map("file_size")            // e.g. "1.2 MB"
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_documents")
}

// =========================================================

enum CATEGORY_TYPE {
  PRODUK
  FORUM
  ARTICLE
}

// =========================================================
// MARKETPLACE B2B - Biomassa & Biochar Products
// =========================================================

model Category {
  id          String    @id @default(uuid())
  name        String    @unique    // e.g. "Limbah Biomassa", "Produk Biochar"
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  categoryType CATEGORY_TYPE @map("category_type")
  productMode  ProductMode?  @map("product_mode") // Separates Biomass vs Organic categories
  biomassaType BiomassaType? @map("biomassa_type") // Required filter for BIOMASS_MATERIAL shelf

  products    Product[]
  articles    Article[]
  forumPosts  ForumPost[]

  @@index([name])
  @@index([categoryType])
  @@index([productMode])
  @@index([productMode, biomassaType])
  @@map("categories")
}

enum ProductStatus {
  ACTIVE
  DRAFT
  INACTIVE
  BLOCKED
  OUT_OF_STOCK
  DELETED
}

enum UnitStatus {
  KG
  TON
}

model Product {
  id            String       @id @default(uuid())
  userId        String                       // SUPPLIER who lists the product
  categoryId    String? @map("category_id")
  name          String                       // e.g. "Sekam Padi Kering Grade A"
  biomassaType  BiomassaType               @map("biomassa_type")  // SEKAM_PADI, TONGKOL_JAGUNG, etc.
  grade         BiocharGrade?              @map("grade")  // Only for BIOCHAR type
  description   String?      @db.Text
  pricePerUnit  Decimal      @db.Decimal(15, 2) @map("price_per_unit")
  originalPrice Decimal?     @db.Decimal(15, 2) @map("original_price") // Harga sebelum diskon (nullable)
  stock         Decimal      @db.Decimal(15, 2) @map("stock") // Changed from Int to support decimal weights (e.g. 1.5 Ton)
  unit          UnitStatus                   @map("unit") // Unit of stock (KG/TON)
  minOrder      Decimal      @db.Decimal(15, 2) @default(100) @map("min_order") // Changed from Int

  // Organic Produce Mode fields
  productMode    ProductMode @default(BIOMASS_MATERIAL) @map("product_mode")
  fertilizerType String?     @map("fertilizer_type")
  isChemicalFree Boolean     @default(false) @map("is_chemical_free")
  cropType       String?     @map("crop_type")

  province      String?                      @map("province") // Location for GIS matching
  regency       String?                      @map("regency")
  thumbnailUrl  String?      @db.Text @map("thumbnail_url")
  status        ProductStatus @default(ACTIVE) @map("status")
  isCertified   Boolean       @default(false)  @map("is_certified") // Verified quality product
  isIotMonitored Boolean     @default(false) @map("is_iot_monitored")
  isEscrowProtected Boolean  @default(true) @map("is_escrow_protected")

  // Cache fields for performance
  averageRating Decimal      @db.Decimal(3, 2) @default(0) @map("average_rating")
  totalReviews  Int          @default(0) @map("total_reviews")
  totalSold     Int          @default(0) @map("total_sold")
  viewCount     Int          @default(0) @map("view_count")

  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  user          User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  category      Category?    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  technicalSpec ProductTechnicalSpec?
  orderItems    OrderItem[]
  negotiations  Negotiation[]
  reviews       Review[]
  images        ProductImage[]
  collections   ProductCollectionItem[]
  cartItems     CartItem[]
  productLikes  ProductLike[]
  specs         ProductSpec[]

  @@index([userId])
  @@index([categoryId])
  @@index([biomassaType])
  @@index([status])
  @@index([totalSold])  
  @@index([createdAt])
  @@index([province, regency])
  @@index([name])
  @@index([productMode])
  @@index([cropType])
  @@map("products")
}

model ProductTechnicalSpec {
  id            String   @id @default(uuid())
  productId     String   @unique @map("product_id")

  // Technical Specs
  carbonPurity        Decimal? @db.Decimal(5, 2) @map("carbon_purity") // % Carbon Purity
  moistureContent     Decimal? @db.Decimal(5, 2) @map("moisture_content") // % Moisture
  surfaceArea         Decimal? @db.Decimal(10, 2) @map("surface_area") // m2/g
  phLevel             Decimal? @db.Decimal(4, 2) @map("ph_level")
  density             String?                   @map("density") // e.g. "95-105 kg/m3"
  productionCapacity  Decimal? @db.Decimal(15, 2) @map("production_capacity") // Monthly capacity Ton
  carbonOffsetPerTon  Decimal? @db.Decimal(10, 2) @map("carbon_offset_per_ton") // tCO2e offset contribution

  // Packaging & Logistics
  grossWeightPerSak   Decimal? @db.Decimal(10, 2)  @map("gross_weight_per_sak") // kg
  netWeightPerSak     Decimal? @db.Decimal(10, 2) @map("net_weight_per_sak") // kg
  bagDimension        String?                   @map("bag_dimension") // e.g. "115x75 cm"
  heavyMetals         Json?                     @map("heavy_metals") // { "As": 10, "Hg": 1, ... }

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_technical_specs")
}

model ProductSpec {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  label     String
  value     String   @db.Text
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, sortOrder])
  @@map("product_specs")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  url       String   @db.Text
  isPrimary Boolean  @default(false) @map("is_primary")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, isPrimary])
  @@index([productId, order])
  @@map("product_images")
}

// =========================================================
// ORDERS & ESCROW TRANSACTIONS
// =========================================================

model Order {
  id            String      @id @default(uuid())
  orderNumber   String      @unique // e.g. #BISA-99283-TRX
  buyerId       String      @map("buyer_id")
  sellerId      String      @map("seller_id")
  status        OrderStatus @default(PENDING) @map("status")

  // Financial Breakdowns (from Invoice UI)
  subtotal      Decimal     @db.Decimal(15, 2) @map("subtotal")
  platformFee   Decimal     @db.Decimal(15, 2) @map("platform_fee") // e.g. 0.5%
  feeBreakdownSnapshot Json? @map("fee_breakdown_snapshot") // e.g. { "feeName": "TRANSACTION_FEE", "type": "PERCENTAGE", "appliedValue": 0.5 }
  logisticsFee  Decimal     @db.Decimal(15, 2) @map("logistics_fee")
  vatAmount     Decimal     @db.Decimal(15, 2) @map("vat_amount") // 11% VAT
  totalAmount   Decimal     @db.Decimal(15, 2) @map("total_amount")
  totalQuantity Decimal     @db.Decimal(15, 2) @map("total_quantity") // Changed from Int to support decimal weights
  specifications String?    @db.Text @map("specifications") // Agreed final specs (PPM, Moisture, etc.)
  creditsApplied Decimal    @db.Decimal(15, 2) @default(0) @map("credits_applied")

  shippingAddressId String? @map("shipping_address_id")
  shippingAddress Address? @relation("ShippingAddress", fields: [shippingAddressId], references: [id], onDelete: Restrict)
  shippingAddressSnapshot Json? @map("shipping_address_snapshot") // Untuk menyimpan data alamat lengkap saat order dibuat (Snapshot)

  /// Satu checkout (multi-supplier) → satu pembayaran gabungan.
  checkoutBatchId String? @map("checkout_batch_id")
  /// Nomor pesanan yang ditampilkan ke buyer (satu per checkout, berbeda dari tracking per supplier).
  checkoutBatchNumber String? @map("checkout_batch_number")

  // Status Badges
  isInsured     Boolean     @default(true) @map("is_insured")
  isDigitalSigned Boolean   @default(true) @map("is_digital_signed")

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  buyer         User        @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Restrict)
  seller        User        @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Restrict)
  shipment      ShipmentTracking?
  orderShipping OrderShipping?
  items         OrderItem[]
  transaction   Transaction?
  negotiation   Negotiation?
  review        Review?
  dispute       OrderDispute?

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([buyerId, status])
  @@index([sellerId, status])
  @@index([checkoutBatchId])
  @@map("orders")
}

model OrderDispute {
  id                 String        @id @default(uuid())
  orderId            String        @unique @map("order_id")
  raisedById         String        @map("raised_by_id")
  reason             String        @db.Text
  description        String?       @db.Text
  evidenceUrls       Json          @default("[]") @map("evidence_urls")
  sellerResponse     String?       @db.Text @map("seller_response")
  sellerEvidenceUrls Json          @default("[]") @map("seller_evidence_urls")
  sellerRespondedAt  DateTime?     @map("seller_responded_at")
  status             DisputeStatus @default(OPEN)
  resolution         String?       @map("resolution")
  resolutionNote     String?       @db.Text @map("resolution_note")
  resolvedAt         DateTime?     @map("resolved_at")
  resolvedById       String?       @map("resolved_by_id")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  order              Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  raisedBy           User          @relation("DisputesRaised", fields: [raisedById], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([createdAt])
  @@map("order_disputes")
}

model ShipmentTracking {
  id            String   @id @default(uuid())
  orderId       String   @unique @map("order_id")

  // Logistics & Route (from Shipment Tracking UI)
  shipmentType  ShipmentType? @default(LAND_CARGO) @map("shipment_type")
  vesselName    String?                    @map("vessel_name") // e.g. "MV Nusantara-9"
  vesselType    VesselType? @default(TRUCK_CARGO) @map("vessel_type")
  originHub     String?                    @map("origin_hub") // e.g. "Semarang Hub"
  destinationHub String?                   @map("destination_hub") // e.g. "Surabaya Industrial Hub"

  // RajaOngkir — resi & lacak ([Tracking AWB](https://rajaongkir.com/docs/shipping-cost/tracking))
  awbNumber            String?   @map("awb_number")
  courierCode          String?   @map("courier_code")
  recipientPhoneLast5  String?   @map("recipient_phone_last5")
  deliveryStatus       String?   @map("delivery_status")
  trackingSnapshot     Json?     @map("tracking_snapshot")
  lastTrackedAt        DateTime? @map("last_tracked_at")

  // Real-time Telemetry
  currentLat    Decimal?    @db.Decimal(10, 8) @map("current_lat")
  currentLng    Decimal?    @db.Decimal(11, 8) @map("current_lng")
  estimatedSpeed String?                   @map("estimated_speed") // e.g. "14.2 Knots"
  aiInsight     String?     @db.Text       @map("ai_insight") // Weather/ETA insights

  // Packaging & Identification
  batchId       String?                    @map("batch_id") // e.g. #BIO-INA-2023-042
  packagingType PackagingType? @default(JUMBO_BAG) @map("packaging_type")

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([awbNumber])
  @@index([courierCode])
  @@map("shipment_tracking")
}

/// Ongkir RajaOngkir yang dipakai saat checkout (1:1 dengan Order)
model OrderShipping {
  id                       String   @id @default(uuid())
  orderId                  String   @unique @map("order_id")
  originDestinationId      Int      @map("origin_destination_id")
  destinationDestinationId Int      @map("destination_destination_id")
  originLabel              String?  @db.Text @map("origin_label")
  destinationLabel         String?  @db.Text @map("destination_label")
  weightGrams              Int      @map("weight_grams")
  courierCode              String   @map("courier_code")
  courierName              String?  @map("courier_name")
  serviceCode              String?  @map("service_code")
  serviceName              String   @map("service_name")
  serviceDescription       String?  @db.Text @map("service_description")
  shippingCost             Decimal  @db.Decimal(15, 2) @map("shipping_cost")
  etd                      String?  @map("etd")
  verifiedAt               DateTime @default(now()) @map("verified_at")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([courierCode])
  @@map("order_shipping")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String         @map("order_id")
  productId   String   @map("product_id")
  quantity    Decimal  @db.Decimal(15, 2) @map("quantity") // Changed from Int
  pricePerUnit Decimal  @db.Decimal(15, 2) @map("price_per_unit")
  subtotal    Decimal  @db.Decimal(15, 2) @map("subtotal")

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Negotiation {
  id            String    @id @default(uuid())
  productId     String    @map("product_id")
  orderId       String?   @unique @map("order_id")
  buyerId       String    @map("buyer_id")
  sellerId      String    @map("seller_id")

  // Quote Details (from Mitra Chat UI)
  quantity      Decimal   @db.Decimal(15, 2) @default(0) @map("quantity") // Changed from Int
  pricePerUnit  Decimal   @db.Decimal(15, 2) @map("price_per_unit")
  moistureLevel Decimal?  @db.Decimal(5, 2) @map("moisture_level") // % Moisture, changed from String for AI
  specifications String?   @db.Text @map("specifications") // Agreed final specs from chat
  roomType      NegotiationRoomType @default(NEGOTIATION) @map("room_type")
  taxStatus     TaxStatus @default(INCLUDED) @map("tax_status")
  totalEstimate Decimal   @db.Decimal(15, 2) @map("total_estimate")

  status        NegotiationStatus @default(OPEN_NEGOTIATION) @map("status") // OPEN, ACCEPTED, REJECTED, LOCKED
  isLocked      Boolean   @default(false) @map("is_locked")
  rejectionReason String? @db.Text @map("rejection_reason")
  closedBy        String? @map("closed_by") // SUPPLIER | BUYER | SYSTEM

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  product       Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  buyer         User      @relation("BuyerNegotiations", fields: [buyerId], references: [id], onDelete: Restrict)
  seller        User      @relation("SellerNegotiations", fields: [sellerId], references: [id], onDelete: Restrict)
  order         Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  messages      ChatMessage[]

  @@index([productId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@index([status, updatedAt])
  @@index([buyerId, productId, roomType, status])
  @@map("negotiations")
}

model ChatMessage {
  id              String   @id @default(uuid())
  negotiationId   String   @map("negotiation_id")
  senderId        String   @map("sender_id")
  content         String   @db.Text @map("content")
  attachmentUrl   String?  @db.Text @map("attachment_url")
  isSystemMessage Boolean  @default(false) @map("is_system_message")
  isRead          Boolean  @default(false) @map("is_read")
  isDeleted       Boolean  @default(false) @map("is_deleted")
  editedAt        DateTime? @map("edited_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  negotiation     Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  sender          User        @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([negotiationId])
  @@index([createdAt])
  @@map("chat_messages")
}

model Transaction {
  id              String            @id @default(uuid())
  orderId         String?           @unique @map("order_id") // Optional to support SUBSCRIPTION transactions
  userId          String            @map("user_id") // Buyer who pays
  amount          Decimal           @db.Decimal(15, 2) @map("amount") // Gross amount paid by buyer
  platformFee     Decimal           @db.Decimal(15, 2) @default(0) @map("platform_fee") // 3% BISA commission
  feeBreakdownSnapshot Json? @map("fee_breakdown_snapshot") // e.g. { "feeName": "ADMIN_FEE", "type": "PERCENTAGE", "appliedValue": 3 }
  sellerAmount    Decimal           @db.Decimal(15, 2) @default(0) @map("seller_amount") // Net amount for supplier
  status          TransactionStatus @default(PENDING)
  type            TransactionType   @default(SALES)
  paymentMethod   PaymentMethod?
  paymentStatus   PaymentStatus?    @default(PENDING)

  // Financial Links
  paymentChannelId String? @map("payment_channel_id")
  payoutAccountId  String? @map("payout_account_id")

  // Payment Provider Details (External)
  externalId       String?          @unique @map("external_id")
  paymentRequestId String? @map("payment_request_id")
  paymentUrl       String?          @db.Text   @map("payment_url")
  providerActions  Json?            @map("provider_actions") // Actions from Xendit/Midtrans

  paymentProofUrl String?           @db.Text @map("payment_proof_url")         // For manual bank transfers
  xenditInvoiceId String?           @unique @map("xendit_invoice_id")
  paymentLink     String?           @db.Text @map("payment_link")
  paidAt          DateTime?         @map("paid_at")
  escrowReleasedAt DateTime?         @map("escrow_released_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  order           Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  user            User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  paymentChannel  PaymentChannel?   @relation(fields: [paymentChannelId], references: [id])
  payoutAccount   UserPayoutAccount? @relation(fields: [payoutAccountId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([paymentStatus])
  @@index([paymentChannelId])
  @@index([payoutAccountId])
  @@index([createdAt])
  @@index([externalId])
  @@index([paymentRequestId])
  @@index([status, type])
  @@index([userId, createdAt])
  @@map("transactions")
}

// =========================================================
// AI PREDICTOR - Biochar Quality & Price Forecast
// =========================================================

model AIPrediction {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  biomassaType   BiomassaType @map("biomassa_type")
  // Input parameters for XGBoost model
  suhuPirolisis  Decimal?     @db.Decimal(6,2)  @map("suhu_pirolisis")  // Pyrolysis temperature (°C)
  waktuPembakaran Int?                           @map("waktu_pembakaran") // Burning time (minutes)
  beratInput     Decimal?     @db.Decimal(10,2) @map("berat_input") // Input biomass weight (kg)
  // AI Output results
  predictedGrade BiocharGrade? @map("predicted_grade")
  predictedYield  Decimal?    @db.Decimal(5,2)  @map("predicted_yield")  // Yield percentage (%)
  cOrganik       Decimal?     @db.Decimal(5,2)  @map("c_organik")  // C-Organic content (%)
  dosis          Decimal?     @db.Decimal(5,2)  @map("dosis")  // Recommended dose ton/ha
  rawOutput      String?      @db.Text          @map("raw_output") // Full JSON output from model
  createdAt      DateTime     @default(now()) @map("created_at")

  user           User         @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("ai_predictions")
}

// =========================================================
// IoT MONITORING - Tungku Pembakaran Biochar
// =========================================================

model IotDevice {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  deviceId    String       @unique   @map("device_id") // Hardware device ID
  name        String?                @map("name") // Custom name e.g. "Tungku Desa Masbagek"
  status      DeviceStatus @default(ACTIVE) @map("status")
  lat         Decimal?     @db.Decimal(10,7) @map("lat") // GPS coordinates
  lng         Decimal?     @db.Decimal(10,7) @map("lng")
  thresholdMin Decimal?     @default(200) @db.Decimal(15,2) @map("threshold_min")
  thresholdMax Decimal?     @default(600) @db.Decimal(15,2) @map("threshold_max")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  readings    IotReading[]
  alerts      IotAlert[]

  @@map("iot_devices")
}

model IotReading {
  id           String    @id @default(uuid())
  deviceId     String    @map("device_id")
  temperature  Decimal   @db.Decimal(6,2)  @map("temperature")  // °C
  humidity     Decimal?  @db.Decimal(5,2)  @map("humidity")  // %
  co2Level     Decimal?  @db.Decimal(8,2)  @map("co2_level")  // ppm
  recordedAt   DateTime  @default(now()) @map("recorded_at")

  device       IotDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, recordedAt])
  @@map("iot_readings")
}

model IotAlert {
  id          String       @id @default(uuid())
  deviceId    String       @map("device_id")
  alertType   IoTAlertType @map("alert_type") // "OVERHEATING", "TEMP_TOO_LOW", "OFFLINE"
  message     String       @db.Text @map("message")
  temperature Decimal?  @db.Decimal(6,2) @map("temperature")
  isRead      Boolean   @default(false) @map("is_read")
  createdAt   DateTime  @default(now()) @map("created_at")

  device      IotDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, createdAt])
  @@index([isRead])
  @@index([deviceId, isRead, createdAt])
  @@map("iot_alerts")
}

